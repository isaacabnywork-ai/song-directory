generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id       Int     @id @default(autoincrement())
  title    String
  artist   String
  year     Int
  category String
  lyrics   String?
  sungCount Int     @default(0)
  audioUrl  String?
}
